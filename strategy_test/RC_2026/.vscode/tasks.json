{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "g++ 编译所有文件",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "*.cpp",
                "*/**.cpp",
                "-o",
                "main.exe",
                "-std=c++17"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "编译所有 C++ 文件"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe 生成活动文件",
            "command": "D:\\Coding_Environment\\GCC\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ]
}